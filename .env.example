# CloudPix — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cloudpix

# Server port (cloud platforms set this automatically)
PORT=3000

# JWT signing secret — use a long random string in production
JWT_SECRET=your_jwt_secret_here

# Admin secret for creator account provisioning (admin portal only)
ADMIN_SECRET=your_admin_secret_here
